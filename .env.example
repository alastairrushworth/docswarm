DOCSWARM_CATALOG_PATH=docswarm_catalog.db
DOCSWARM_DATA_PATH=docswarm_data/
DOCSWARM_PDF_DIR=pdfs/
DOCSWARM_PAGES_DIR=pages/
DOCSWARM_OCR_LANGUAGE=eng
DOCSWARM_CHUNK_SIZE=800
DOCSWARM_CHUNK_OVERLAP=100
DOCSWARM_MODEL=qwen3.5:4b
DOCSWARM_OLLAMA_BASE_URL=http://localhost:11434
DOCSWARM_WIKI_OUTPUT_DIR=wiki/
DOCSWARM_WIKI_URL=http://localhost:3000
DOCSWARM_WIKI_API_KEY=
